{
  "name": "floating-clock",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node --test",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && electron-builder",
    "preview": "vite preview    "
  },
  "dependencies": {
    "vue": "^3.5.25",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-store": "^11.0.2",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.floatingclock.app",
    "productName": "悬浮时钟",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  }
}
